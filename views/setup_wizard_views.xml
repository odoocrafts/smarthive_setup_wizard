<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smarthive_setup_wizard_form" model="ir.ui.view">
        <field name="name">smarthive.setup.wizard.form</field>
        <field name="model">smarthive.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="Smarthive Setup" class="smarthive-setup-container">
                <field name="state" invisible="1"/>
                
                <!-- Welcome State -->
                <div invisible="state != 'welcome'" class="smarthive-step-content text-center">
                    <div class="smarthive-setup-header">
                        <h1>Welcome to Smarthive! 🐝</h1>
                        <p>Thank you for choosing us. Let's get your institute up and running.</p>
                    </div>
                </div>

                <!-- Company State -->
                <div invisible="state != 'company'" class="smarthive-step-content">
                    <div class="smarthive-setup-header">
                        <h1>Company Profile</h1>
                        <p>Set up your core institute details to appear on reports and invoices.</p>
                    </div>
                    <group>
                        <group>
                            <field name="company_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="company_logo" widget="image" class="oe_avatar"/>
                        </group>
                        <label for="street" string="Address"/>
                        <div class="o_address_format">
                            <field name="street" placeholder="Street..." class="o_address_street"/>
                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                            <field name="city" placeholder="City" class="o_address_city"/>
                            <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True, 'no_quick_create': True}"/>
                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                            <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_open': True, 'no_quick_create': True}"/>
                        </div>
                    </group>
                </div>

                <!-- Sales Team State -->
                <div invisible="state != 'sales_team'" class="smarthive-step-content">
                    <div class="smarthive-setup-header">
                        <h1>Sales Team</h1>
                        <p>Establish your main sales or admission team.</p>
                    </div>
                    <group>
                        <field name="sales_team_name"/>
                    </group>
                </div>

                <!-- Salesperson State -->
                <div invisible="state != 'salesperson'" class="smarthive-step-content">
                    <div class="smarthive-setup-header">
                        <h1>Salespeople</h1>
                        <p>Add your admission officers or sales agents.</p>
                    </div>
                    <field name="salesperson_line_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="login"/>
                            <field name="password" password="True"/>
                        </tree>
                    </field>
                </div>

                <!-- Courses State -->
                <div invisible="state != 'courses'" class="smarthive-step-content">
                    <div class="smarthive-setup-header">
                        <h1>Courses &amp; Products</h1>
                        <p>Define the core programs your institute offers.</p>
                    </div>
                    <field name="course_line_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="course_code"/>
                            <field name="course_type"/>
                            <field name="semester_count"/>
                        </tree>
                    </field>
                </div>

                <!-- Intro Books State -->
                <div invisible="state != 'intro_books'" class="smarthive-step-content">
                    <div class="smarthive-marketing-box">
                        <div class="smarthive-marketing-icon">📚</div>
                        <div class="smarthive-marketing-text">
                            <h2>Intro to Books App</h2>
                            <p>A mini, but incredibly smart and effective solution tailored for your institute's everyday accounting. Manage fees, expenses, and transaction vouchers with ease.</p>
                        </div>
                    </div>
                </div>

                <!-- Intro Student State -->
                <div invisible="state != 'intro_student'" class="smarthive-step-content">
                    <div class="smarthive-marketing-box">
                        <div class="smarthive-marketing-icon">🎓</div>
                        <div class="smarthive-marketing-text">
                            <h2>Student Management Module</h2>
                            <p>An all-in-one student management solution. Track admissions, academic standing, and demographic records holistically within Smarthive.</p>
                        </div>
                    </div>
                </div>

                <!-- Help State -->
                <div invisible="state != 'help'" class="smarthive-step-content text-center">
                    <div class="smarthive-marketing-box" style="justify-content: center; text-align: center; flex-direction: column;">
                        <div class="smarthive-marketing-icon">🎧</div>
                        <div class="smarthive-marketing-text">
                            <h2>Help is One Click Away</h2>
                            <p>Need assistance or have special requirements? We've got you covered.</p>
                            <br/>
                            <a href="https://odoocrafts.com/helpdesk/customer-care-1?contact_form=1" target="_blank" style="margin-top:15px; display:inline-block;" class="btn btn-primary smarthive-wizard-btn smarthive-wizard-btn-primary">
                                Contact Customer Care
                            </a>
                        </div>
                    </div>
                </div>
                
                <footer>
                    <button string="Previous" invisible="state == 'welcome' or state == 'done'" name="action_previous" type="object" class="btn btn-secondary smarthive-wizard-btn"/>
                    
                    <button string="Next" invisible="state == 'help' or state == 'done'" name="action_next" type="object" class="btn btn-primary smarthive-wizard-btn smarthive-wizard-btn-primary"/>
                    
                    <button string="Finish &amp; Apply" invisible="state != 'help'" name="action_finish" type="object" class="btn btn-primary smarthive-wizard-btn smarthive-wizard-btn-primary"/>
                    
                    <button string="Cancel Setup" invisible="state == 'done'" class="btn btn-link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Setup Action -->
    <record id="action_smarthive_setup_wizard" model="ir.actions.act_window">
        <field name="name">Smarthive Setup</field>
        <field name="res_model">smarthive.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Root Menu Item -->
    <menuitem id="menu_smarthive_setup_root"
              name="Smarthive Setup"
              web_icon="crm,static/description/icon.png"
              action="action_smarthive_setup_wizard"
              sequence="-5"/>
</odoo>
